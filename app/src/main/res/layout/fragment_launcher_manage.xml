<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/manageScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="管理"
                android:textColor="@color/launcher_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/manageActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/actionAddDirectory"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="D" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="添加目录" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionScanGame"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="S" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="扫描游戏" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionAddGame"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="+" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="添加游戏" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionCloudSync"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="C" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="云端同步" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionModelSettings"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="M" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="设置模型" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionFeedback"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="F" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="建议反馈" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
