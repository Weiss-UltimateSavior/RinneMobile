<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/manageScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="@dimen/launcher_nav_overlay_scroll_bottom_padding"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="25dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="管理"
                android:textColor="@color/launcher_text_color"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/manageActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/actionAddDirectory"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="D" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="添加目录" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionScanGame"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="S" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="扫描游戏" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionAddGame"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="+" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="添加游戏" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionCloudSync"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="C" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="云端同步" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionDiagnostics"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="L" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="日志诊断" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionMetadataSource"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="S" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="封面设置" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionKrkrSettings"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="K" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="引擎设置" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:text="扫描目录"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/scanDirectoryList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/scanDirectoryEmpty"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="9dp"
                android:background="@drawable/launcher_white_card"
                android:gravity="center"
                android:text="还没有添加扫描目录"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/scanResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="最近扫描结果"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/scanResultDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:background="@drawable/launcher_white_card"
                android:orientation="vertical"
                android:padding="13dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
