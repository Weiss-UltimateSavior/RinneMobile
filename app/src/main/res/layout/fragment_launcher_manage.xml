<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/manageScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="18dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="管理"
                android:textColor="@color/launcher_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/manageActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/actionAddDirectory"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="D" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="添加目录" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionScanGame"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="S" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="扫描游戏" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionAddGame"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="+" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="添加游戏" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionCloudSync"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="C" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="云端同步" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionModelSettings"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="AI" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="智能评价" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionDiagnostics"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="L" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="日志诊断" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionMetadataSource"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="S" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="资料源设置" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionKrkrSettings"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="K" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="KRKR 引擎" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="扫描目录"
                android:textColor="@color/launcher_text_color"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/scanDirectoryList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/scanDirectoryEmpty"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/launcher_white_card"
                android:gravity="center"
                android:text="还没有添加扫描目录"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/scanResultTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="最近扫描结果"
                android:textColor="@color/launcher_text_color"
                android:textSize="17sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/scanResultDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/launcher_white_card"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
