<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/editScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="31dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="编辑游戏"
                android:textColor="@color/launcher_text_color"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="标题"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTitle"
                style="@style/LauncherFormInput"
                android:layout_marginTop="5dp"
                android:hint="游戏标题"
                android:inputType="text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="引擎"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/editEngine"
                style="@style/LauncherFormSpinner"
                android:layout_marginTop="5dp"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="模拟器包名"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editEmulator"
                style="@style/LauncherFormInput"
                android:layout_marginTop="5dp"
                android:hint="留空使用默认"
                android:inputType="text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="启动目标"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editLaunchTarget"
                style="@style/LauncherFormInput"
                android:layout_marginTop="5dp"
                android:hint="[游戏目录]"
                android:inputType="text" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="GameHub localGameId"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/editGameHubLocalGameId"
                    style="@style/LauncherFormInput"
                    android:layout_width="0dp"
                    android:layout_marginTop="0dp"
                    android:layout_weight="1"
                    android:hint="选择 GameHub 引擎后可从盖世导入"
                    android:inputType="text" />

                <TextView
                    android:id="@+id/btnImportGameHubShortcut"
                    style="@style/LauncherInlineActionButton"
                    android:layout_marginStart="7dp"
                    android:text="导入"
                    />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="描述"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editDescription"
                style="@style/LauncherFormMultilineInput"
                android:layout_marginTop="5dp"
                android:hint="可选描述"
                android:inputType="textMultiLine"
                />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="游戏目录"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/editDir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="middle"
                android:maxLines="2"
                android:text="尚未选择游戏目录"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnPickDirectory"
                style="@style/LauncherLongActionButton"
                android:layout_marginTop="10dp"
                android:contentDescription="选择游戏目录"
                android:text="选择游戏目录"
                />

            <TextView
                android:id="@+id/editCoverStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="封面：未选择封面"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnPickCover"
                style="@style/LauncherLongActionButton"
                android:layout_marginTop="5dp"
                android:text="选择封面"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/btnSave"
                    style="@style/LauncherLongActionButton"
                    android:text="保存"
                    />

                <TextView
                    android:id="@+id/btnCancel"
                    style="@style/LauncherLongActionButton"
                    android:layout_marginTop="9dp"
                    android:text="取消"
                    />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
