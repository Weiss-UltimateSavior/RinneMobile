<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/translationSettingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/translationScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="31dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="智能翻译"
                android:textColor="@color/launcher_text_color"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:lineSpacingExtra="3dp"
                android:text="开启后屏幕上会出现悬浮按钮，游玩 Galgame 时点击该按钮会自动截取当前画面并调用多模态 AI 模型翻译图中的对话。"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    android:text="启用悬浮翻译"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/translationEnabledSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="API 配置"
                android:textColor="@color/launcher_text_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:lineSpacingExtra="2dp"
                android:text="配置兼容 OpenAI 的多模态模型地址、模型名称与 API Key。"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="11sp" />

            <EditText
                android:id="@+id/translationBaseUrlInput"
                style="@style/LauncherFormInput"
                android:hint="API 地址 (HTTPS)"
                android:inputType="textUri"
                android:singleLine="true" />

            <EditText
                android:id="@+id/translationModelInput"
                style="@style/LauncherFormInput"
                android:hint="模型名称 (如 gpt-4o-mini)"
                android:inputType="text"
                android:singleLine="true" />

            <EditText
                android:id="@+id/translationApiKeyInput"
                style="@style/LauncherFormInput"
                android:hint="API Key (留空表示不修改)"
                android:inputType="textPassword"
                android:singleLine="true" />

            <TextView
                android:id="@+id/translationTestButton"
                style="@style/LauncherShortSecondaryActionButton"
                android:layout_width="match_parent"
                android:layout_height="41dp"
                android:layout_marginTop="14dp"
                android:text="测试链接" />

            <TextView
                android:id="@+id/translationSaveButton"
                style="@style/LauncherLongActionButton"
                android:layout_marginTop="9dp"
                android:text="保存配置" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    android:text="悬浮窗权限"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/translationOverlayStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未授权"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/translationOverlayButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@null"
                    android:textColor="@color/launcher_primary_color"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:text="授权" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:lineSpacingExtra="2dp"
                    android:text="截屏权限"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/translationProjectionStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="未授权"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
