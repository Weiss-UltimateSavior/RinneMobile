<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/aiReviewScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="34dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="智能评价"
                android:textColor="@color/launcher_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="配置模型后，后续可在 Launcher 内生成 Galgame 游玩点评"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="14sp" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:layout_marginTop="24dp"
                android:text="服务商" />

            <Spinner
                android:id="@+id/aiReviewProviderSpinner"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/launcher_account_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="接口地址" />

            <EditText
                android:id="@+id/aiReviewBaseUrlInput"
                style="@style/LauncherAddGameInput"
                android:hint="https://api.deepseek.com/v1"
                android:inputType="textUri" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="API Key" />

            <EditText
                android:id="@+id/aiReviewApiKeyInput"
                style="@style/LauncherAddGameInput"
                android:hint="sk-..."
                android:inputType="textPassword" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="模型名称" />

            <EditText
                android:id="@+id/aiReviewModelInput"
                style="@style/LauncherAddGameInput"
                android:hint="deepseek-chat / gpt-4o-mini" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="评价角色" />

            <Spinner
                android:id="@+id/aiReviewPersonaSpinner"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/launcher_account_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="剧透控制" />

            <Spinner
                android:id="@+id/aiReviewSpoilerSpinner"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/launcher_account_input"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="温度" />

            <EditText
                android:id="@+id/aiReviewTemperatureInput"
                style="@style/LauncherAddGameInput"
                android:hint="0.85"
                android:inputType="numberDecimal" />

            <CheckBox
                android:id="@+id/aiReviewFullEndpointCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="接口地址已包含 /chat/completions"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/aiReviewMetadataEnhanceCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="启用资料增强"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/aiReviewMetadataOnlineCheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="允许在线资料查询"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="系统提示词" />

            <EditText
                android:id="@+id/aiReviewPromptInput"
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/launcher_account_input"
                android:gravity="top"
                android:hint="输入智能评价的角色与语气"
                android:paddingStart="14dp"
                android:paddingTop="12dp"
                android:paddingEnd="14dp"
                android:paddingBottom="12dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/aiReviewHistory"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="点评历史"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/aiReviewGenerate"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="生成点评"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/aiReviewSave"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text="保存配置"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
