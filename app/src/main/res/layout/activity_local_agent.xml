<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/agentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/agentMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/agentEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/agentEmptyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="创建一个游戏维护任务"
            android:textColor="@color/launcher_text_color"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/agentEmptyDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="描述游戏配置修改需求。智能体会先制定步骤，目录读取或文件写入时再确认。"
            android:textColor="@color/launcher_text_muted_color"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agentTopOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="6dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/agentTitleBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingStart="13dp"
            android:paddingTop="8dp"
            android:paddingEnd="13dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="34dp"
                android:text="Rinne"
                android:textColor="@color/launcher_on_primary_color"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/agentInfoBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/launcher_white_card"
            android:gravity="center_vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/agentStateLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="工作台待命"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/agentHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="2"
                    android:text="配置模型后即可创建任务"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/agentStateIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="智能体设置"
                android:padding="3dp"
                android:scaleType="fitCenter"
                android:src="@drawable/launcher_agent_settings" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agentComposerOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/launcher_bg_color"
        android:elevation="0dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/agentInputThemeBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/launcher_white_card"
            android:elevation="0dp"
            android:minHeight="106dp"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="0dp">

            <com.apps.widget.LauncherEditText
                android:id="@+id/agentInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:gravity="top|start"
                android:hint="请输入你的指令"
                android:inputType="textMultiLine|textCapSentences"
                android:maxHeight="128dp"
                android:maxLines="5"
                android:minHeight="40dp"
                android:padding="0dp"
                android:singleLine="false"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <HorizontalScrollView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:fillViewport="false"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/agentQuickInspect"
                            android:layout_width="wrap_content"
                            android:layout_height="27dp"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="API 配置"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/agentQuickLocate"
                            android:layout_width="wrap_content"
                            android:layout_height="27dp"
                            android:layout_marginStart="6dp"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="修改记录"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/agentQuickHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="27dp"
                            android:layout_marginStart="6dp"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="清空会话"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>

                <ImageView
                    android:id="@+id/agentSend"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="10dp"
                    android:contentDescription="执行或停止任务"
                    android:padding="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/launcher_ic_send" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
