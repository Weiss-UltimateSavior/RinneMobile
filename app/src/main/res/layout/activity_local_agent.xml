<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/agentRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/agentMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:scrollbars="none" />

    <LinearLayout
        android:id="@+id/agentEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/agentEmptyTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="创建一个游戏维护任务"
            android:gravity="center"
            android:textColor="@color/launcher_text_color"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/agentEmptyDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="本地 AI 智能体，运行在设备端，模型负责推理、本地工具负责执行。支持查询与筛选游戏库、浏览游戏文件、多编码读取与搜索文本、精确替换文件内容（需逐次确认）、修改快照恢复。可通过工作区命令检查文件、解析 JSON/INI/XML、诊断编码。支持整理扫描目录（移动/重命名/创建文件夹）、私有工作空间自由读写，以及通过 MCP 协议连接远程工具服务器扩展能力。所有写入与远程调用均需本机确认。"
            android:textColor="@color/launcher_text_muted_color"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agentTopOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:elevation="6dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/agentTitleBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingStart="13dp"
            android:paddingTop="8dp"
            android:paddingEnd="13dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minHeight="34dp"
                android:text="Rinne"
                android:textColor="@color/launcher_on_primary_color"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/agentInfoBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/launcher_white_card"
            android:gravity="center_vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/agentStateLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="工作台待命"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/agentHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="2"
                    android:text="配置模型后即可创建任务"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/agentStateIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:contentDescription="智能体设置"
                android:padding="3dp"
                android:scaleType="fitCenter"
                android:src="@drawable/launcher_agent_settings" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/agentComposerOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/launcher_bg_color"
        android:elevation="0dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/agentInputThemeBar"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:background="@drawable/launcher_white_card"
            android:elevation="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="4dp">

            <com.apps.widget.LauncherEditText
                android:id="@+id/agentInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:gravity="center_vertical|start"
                android:hint="请输入你的指令"
                android:inputType="textMultiLine|textCapSentences"
                android:maxHeight="28dp"
                android:maxLines="2"
                android:minHeight="14dp"
                android:padding="0dp"
                android:singleLine="false"
                android:textColor="@color/launcher_text_color"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/agentSend"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="执行或停止任务"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/launcher_ic_send" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
