<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/aiChatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/aiChatMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:id="@+id/aiChatTopOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:clipToPadding="false"
        android:elevation="6dp"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/aiChatTitleBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingStart="13dp"
            android:paddingTop="12dp"
            android:paddingEnd="13dp"
            android:paddingBottom="15dp">

            <TextView
                android:id="@+id/aiChatTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/launcher_text_color"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/aiChatInfoBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/launcher_white_card"
            android:gravity="center_vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/aiChatCharacterIcon"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:gravity="center"
                android:text="AI"
                android:textColor="@color/launcher_on_primary_color"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aiChatHint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="9dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="加载聊天记录中…"
                android:textColor="@color/launcher_text_color"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/aiChatComposerOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:elevation="6dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/aiChatClear"
                android:layout_width="wrap_content"
                android:layout_height="31dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="清空记录"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/aiChatCustomModel"
                android:layout_width="wrap_content"
                android:layout_height="31dp"
                android:layout_marginStart="7dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="自定义模型"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/aiChatInputThemeBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:id="@+id/aiChatInputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/launcher_white_card"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingTop="3dp"
                android:paddingEnd="8dp"
                android:paddingBottom="3dp">

                <EditText
                    android:id="@+id/aiChatInput"
                    style="@style/LauncherAddGameInput"
                    android:layout_width="0dp"
                    android:layout_height="33dp"
                    android:layout_marginTop="0dp"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="说点什么…"
                    android:includeFontPadding="false"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLines="4"
                    android:minHeight="0dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp" />

                <ImageView
                    android:id="@+id/aiChatSend"
                    android:layout_width="56dp"
                    android:layout_height="43dp"
                    android:layout_marginStart="4dp"
                    android:contentDescription="发送消息"
                    android:padding="6dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/launcher_ic_send" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
