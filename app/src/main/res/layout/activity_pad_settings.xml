<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <com.apps.theme.LauncherParticleView
        android:id="@+id/padSettingsParticleView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/padSettingsContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="18dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/launcher_white_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/padSettingsSidebarGeneral"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="常规设置"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/padSettingsSidebarTheme"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="主题设置"
                android:textColor="@color/launcher_text_color"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/padSettingsSidebarMetadata"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="封面设置"
                android:textColor="@color/launcher_text_color"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/padSettingsSidebarAccount"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="账号设置"
                android:textColor="@color/launcher_text_color"
                android:textSize="14sp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/padSettingsBackButton"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center"
                android:text="返回"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="14dp"
            android:layout_weight="3"
            android:orientation="vertical">

            <TextView
                android:id="@+id/padSettingsPageTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="常规"
                android:textColor="@color/launcher_text_color"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/padSettingsPageDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="设置项暂仅展示，不会改变应用行为"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="11sp" />

            <ScrollView
                android:id="@+id/padSettingsActionScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="18dp"
                android:fillViewport="true"
                android:layout_weight="1"
                android:overScrollMode="ifContentScrolls">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

            <LinearLayout
                android:id="@+id/padSettingsGeneralActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KR 引擎版本"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/padEngineVersionSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="5dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="KR 启动参数兼容模式"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/padCompatModeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="KR 独立存档目录（权限异常闪退时开启）"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/padKrScopedSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Artemis 独立存档目录（权限异常闪退时开启）"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/padArtemisScopedSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/padNativeKrkrButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="进入原生 KRKR"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/padKrkrCancelButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="取消"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/padKrkrSaveButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="保存"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/padSettingsThemeActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/padFreshThemeRow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/launcher_chat_option_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/padFreshThemeIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:clipToOutline="true"
                        android:contentDescription="清新绿意主题"
                        android:scaleType="centerCrop"
                        android:src="@drawable/launcher_theme_default_logo" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="丛雨（默认）"
                            android:textColor="@color/launcher_text_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="当前启动界面的默认主题"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/padFreshThemeCheck"
                        android:layout_width="22dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="✓"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/padRinneThemeRow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/launcher_chat_option_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/padRinneThemeLogo"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:clipToOutline="true"
                        android:contentDescription="园神凛弥主题"
                        android:scaleType="centerCrop"
                        android:src="@drawable/launcher_theme_rinne_logo" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="园神凛弥（风格）"
                            android:textColor="@color/launcher_text_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="不断的轮回，只为迎接新的未来"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/padRinneThemeCheck"
                        android:layout_width="22dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="✓"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/padAnriThemeRow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/launcher_chat_option_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/padAnriThemeLogo"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:clipToOutline="true"
                        android:contentDescription="鹰仓杏璃主题"
                        android:scaleType="centerCrop"
                        android:src="@drawable/launcher_theme_anri_logo" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="鹰仓杏璃（风格）"
                            android:textColor="@color/launcher_text_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="能对你为所欲为的，只有我"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/padAnriThemeCheck"
                        android:layout_width="22dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="✓"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/padXinhaitianThemeRow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/launcher_chat_option_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <ImageView
                        android:id="@+id/padXinhaitianThemeLogo"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:clipToOutline="true"
                        android:contentDescription="心海天主题"
                        android:scaleType="centerCrop"
                        android:src="@drawable/launcher_theme_xinhaitian_logo" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="心海天（风格）"
                            android:textColor="@color/launcher_text_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="心海澄澈，天光温柔"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/padXinhaitianThemeCheck"
                        android:layout_width="22dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="✓"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/padParticleToggleRow"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/launcher_chat_option_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">

                    <TextView
                        android:id="@+id/padParticleToggleIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="P"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="动态粒子"
                            android:textColor="@color/launcher_text_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="控制 Launcher 背景的小圆点特效"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/padParticleToggleState"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/padThemeApply"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="应用"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/padSettingsMetadataActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="资料源"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/padMetadataSourceSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="5dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Bangumi Access Token"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/padMetadataTokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/launcher_account_input"
                    android:hint="选择 Bangumi 时必填"
                    android:inputType="textVisiblePassword"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:textColor="@color/launcher_text_color"
                    android:textColorHint="@color/launcher_input_hint_color"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/padMetadataTokenLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="没有 Token？前往申请"
                    android:textColor="@color/launcher_primary_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="2dp"
                    android:text="Bangumi Token 建议使用注册超过三个月的账号申请。月幕 Gal 使用公开 API，无需 Token。切换资料源后，可对当前游戏重新匹配以刷新资料与封面。"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/padMetadataCancelButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="取消"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/padMetadataSaveButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="保存"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/padSettingsAccountActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/padRowSyncConfig"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="应用配置同步"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/padChipSyncConfig"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/padRowRealtimePlaytime"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="实时游玩时间"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/padChipRealtimePlaytime"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/padRowEmailSubscribe"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="邮箱信息订阅"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/padChipEmailSubscribe"
                        android:layout_width="52dp"
                        android:layout_height="30dp"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
