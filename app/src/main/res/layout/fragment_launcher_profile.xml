<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/profileScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:layout_marginBottom="@dimen/launcher_bottom_nav_height"
        android:overScrollMode="never"
        android:paddingBottom="0dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="25dp">

            <!-- 顶部个人信息区域 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/launcher_profile_list_bg"
                android:clipToOutline="true">

                <!-- 背景图片：跟随主题切换 -->
                <ImageView
                    android:id="@+id/profileBgImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.65"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/launcher_home_stats_bg" />

                <ImageView
                    android:id="@+id/actionChangeCover"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="54dp"
                    android:layout_marginEnd="11dp"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:contentDescription="更换封面"
                    android:focusable="true"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/launcher_icon_edit" />



                <LinearLayout
                    android:id="@+id/profileHeader"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="34dp"
                    android:paddingTop="25dp"
                    android:paddingEnd="34dp"
                    android:paddingBottom="18dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="69dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/profileAvatar"
                            android:layout_width="59dp"
                            android:layout_height="59dp"
                            android:background="@drawable/launcher_avatar"
                            android:clipToOutline="true"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:src="@drawable/launcher_default_avatar" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="15dp"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/profileNickname"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="本地用户"
                                android:textColor="@color/launcher_text_color"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/profileEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text=""
                                android:textColor="@color/launcher_text_color"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/launcher_white_card"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="近 7 日实际游玩时长"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <com.apps.widget.LauncherWeeklyPlaytimeChartView
                    android:id="@+id/profileWeeklyPlaytimeChart"
                    android:layout_width="match_parent"
                    android:layout_height="126dp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/profilePlaytimeRankCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="游玩时长排名"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/profilePlaytimeRankValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="加载中…"
                        android:textColor="@color/launcher_text_muted_color"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/profilePlaytimeTotalIcon"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="排行榜"
                        android:padding="5dp"
                        android:src="@drawable/launcher_ic_leaderboard" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="总时长"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/profilePlaytimeTotalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="--"
                            android:textColor="@color/launcher_text_color"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 功能列表 -->
            <LinearLayout
                android:id="@+id/profileActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/saveManagerRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="V" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="存档管理" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                    android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/moduleCompatibilityRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="M" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="模块兼容" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/profileInfoRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="P" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="个人资料" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/accountSettingsRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="A" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="账号设置" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cloudRestoreRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="C" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="配置恢复" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/logoutRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="L" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="退出登录" />

                    <ImageView
                        style="@style/LauncherManageArrowIcon"
                        android:contentDescription="@null"
                        android:src="@drawable/launcher_manage_arrow" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
