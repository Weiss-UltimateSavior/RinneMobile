<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/profileScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="25dp">

            <!-- 顶部个人信息区域 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="225dp"
                android:background="@drawable/launcher_profile_list_bg"
                android:clipToOutline="true">

                <!-- 背景图片：跟随主题切换 -->
                <ImageView
                    android:id="@+id/profileBgImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0.65"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/launcher_home_stats_bg" />

                <ImageView
                    android:id="@+id/actionChangeCover"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end|top"
                    android:layout_marginTop="54dp"
                    android:layout_marginEnd="11dp"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:contentDescription="更换封面"
                    android:focusable="true"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/launcher_icon_edit" />



                <LinearLayout
                    android:id="@+id/profileHeader"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="34dp"
                    android:paddingTop="25dp"
                    android:paddingEnd="34dp"
                    android:paddingBottom="18dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="69dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/profileAvatar"
                            android:layout_width="59dp"
                            android:layout_height="59dp"
                            android:background="@drawable/launcher_avatar"
                            android:clipToOutline="true"
                            android:contentDescription="@null"
                            android:scaleType="centerCrop"
                            android:src="@drawable/launcher_default_avatar" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="15dp"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/profileNickname"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="本地用户"
                                android:textColor="@color/launcher_text_color"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/profileEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text=""
                                android:textColor="@color/launcher_text_color"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- 功能列表 -->
            <LinearLayout
                android:id="@+id/profileActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="25dp"
                android:layout_marginEnd="20dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/profileInfoRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="P" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="个人资料" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/accountSettingsRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="A" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="账号设置" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/helpCenterRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="H" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="帮助中心" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/logoutRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="L" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="退出登录" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>