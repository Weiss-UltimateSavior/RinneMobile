<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/profileScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="28dp">

            <!-- 顶部个人信息区域 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:background="@drawable/launcher_profile_list_bg"
                android:clipToOutline="true">

                <!-- 背景图片：对应 app/src/main/res/drawable-nodpi/launcher_home_stats_bg.png -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="1"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/launcher_home_stats_bg" />

                <!-- 半透明遮罩，防止文字看不清 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/launcher_surface_overlay_color" />

                <LinearLayout
                    android:id="@+id/profileHeader"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="38dp"
                    android:paddingTop="28dp"
                    android:paddingEnd="38dp"
                    android:paddingBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="77dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:background="@drawable/launcher_avatar"
                            android:gravity="center"
                            android:text="Y"
                            android:textColor="@color/launcher_on_primary_color"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="17dp"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="本地用户"
                                android:textColor="@color/launcher_text_color"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:text="rinne@example.com"
                                android:textColor="@color/launcher_text_color"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <!-- 功能列表 -->
            <LinearLayout
                android:id="@+id/profileActionList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="22dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/profileInfoRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="P" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="个人资料" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/accountSettingsRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="A" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="账号设置" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/helpCenterRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="H" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="帮助中心" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/privacyPolicyRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="PR" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="隐私政策" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/aboutYukiHubRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="i" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="兑换入口" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/logoutRow"
                    style="@style/LauncherManageItem">

                    <TextView
                        style="@style/LauncherManageIcon"
                        android:text="L" />

                    <TextView
                        style="@style/LauncherManageTitle"
                        android:text="退出登录" />

                    <TextView
                        style="@style/LauncherManageArrow"
                        android:text=">" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>