<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/toolboxScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="25dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工具箱"
                android:textColor="@color/launcher_text_color"
                android:textSize="22sp"
                android:textStyle="bold" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="50dp"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:useDefaultMargins="false">

                <LinearLayout
                    android:id="@+id/toolWinlator"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="winlator"
                        android:src="@drawable/launcher_tool_icon_winlator" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="winlator" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolGaishi"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="盖世模拟器"
                        android:src="@drawable/launcher_tool_icon_gaishi" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="盖世模拟器" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolPpsspp"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="PPSSPP"
                        android:src="@drawable/launcher_tool_icon_ppsspp" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="PPSSPP" />
                </LinearLayout>

            </GridLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:useDefaultMargins="false">

                <LinearLayout
                    android:id="@+id/toolUsefulUnpack"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="usefulunpack"
                        android:src="@drawable/launcher_tool_icon_usefulunpack" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="usefulunpack" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolTermux"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="termux"
                        android:src="@drawable/launcher_tool_icon_termux" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="termux" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolShizuku"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="shizuku"
                        android:src="@drawable/launcher_tool_icon_shizuku" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="shizuku" />
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
