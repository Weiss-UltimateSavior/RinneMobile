<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/toolboxScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工具箱"
                android:textColor="@color/launcher_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="20dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/toolboxNoticeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="优质的Galgame辅助工具"
                    android:textColor="@color/launcher_primary_color"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/toolboxNoticeText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="使用工具进行辅助，让你的游玩更加便捷！仅作推荐喵"
                    android:textColor="@color/launcher_primary_color"
                    android:textSize="14sp" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:useDefaultMargins="false">

                <LinearLayout
                    android:id="@+id/toolUsefulUnpack"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="usefulunpack"
                        android:src="@drawable/launcher_tool_icon_usefulunpack" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="usefulunpack" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolTermux"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="termux"
                        android:src="@drawable/launcher_tool_icon_termux" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="termux" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolShizuku"
                    style="@style/LauncherToolboxItem">

                    <ImageView
                        style="@style/LauncherToolboxIcon"
                        android:contentDescription="shizuku"
                        android:src="@drawable/launcher_tool_icon_shizuku" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="shizuku" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolRecharge"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_orange" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="记录换算" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolPayBill"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_green" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="路径检查" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolCreditCard"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_red" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="缓存清理" />
                </LinearLayout>


            </GridLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
