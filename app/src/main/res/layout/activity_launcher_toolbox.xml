<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/toolboxScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="28dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工具箱"
                android:textColor="@color/launcher_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/toolboxNoticeCard"
                android:layout_width="match_parent"
                android:layout_height="142dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/launcher_balance_card"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="工具推荐声明"
                        android:textColor="@color/launcher_on_primary_color"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="本页工具仅作推荐，请根据实际需要自行斟酌使用。"
                        android:textColor="@color/launcher_balance_text_color"
                        android:textSize="14sp" />
                </LinearLayout>
            </FrameLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:alignmentMode="alignMargins"
                android:columnCount="3"
                android:useDefaultMargins="false">

                <LinearLayout
                    android:id="@+id/toolTranslate"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_blue" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="文本翻译" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolArchive"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_red" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="资源整理" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolLauncher"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_blue" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="启动助手" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolRecharge"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_orange" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="记录换算" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolPayBill"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_green" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="路径检查" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolCreditCard"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_red" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="缓存清理" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/toolReport"
                    style="@style/LauncherToolboxItem">

                    <TextView
                        style="@style/LauncherToolboxIcon"
                        android:background="@drawable/launcher_tool_icon_blue" />

                    <TextView
                        style="@style/LauncherToolboxTitle"
                        android:text="运行报告" />
                </LinearLayout>
            </GridLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
