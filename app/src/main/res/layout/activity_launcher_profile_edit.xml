<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/profileEditScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="25dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="个人资料"
                android:textColor="@color/launcher_text_color"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- 修改用户名 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="修改用户名"
                android:textColor="@color/launcher_text_color"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="新用户名"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputNewUsername"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="3-32位字母、数字或下划线"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <!-- 修改密码 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="修改密码"
                android:textColor="@color/launcher_text_color"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:text="旧密码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputOldPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="输入当前密码"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="新密码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputNewPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="6-128位"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:text="确认新密码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/inputConfirmNewPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="再次输入新密码"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:gravity="center"
                android:text="修改密码后需重新登录"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/btnUpdateUsername"
                    style="@style/LauncherLongActionButton"
                    android:text="修改用户名"
                    />

                <TextView
                    android:id="@+id/btnUpdatePassword"
                    style="@style/LauncherLongActionButton"
                    android:layout_marginTop="9dp"
                    android:text="修改密码"
                    />

                <TextView
                    android:id="@+id/profileEditBack"
                    style="@style/LauncherLongActionButton"
                    android:layout_marginTop="9dp"
                    android:text="返回"
                    />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
