<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/recentRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.core.widget.NestedScrollView
    android:id="@+id/contentScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="25dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/launcherAvatarContainer"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:background="@drawable/launcher_avatar"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackgroundBorderless">

                <TextView
                    android:id="@+id/launcherAvatarInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Y"
                    android:textColor="@color/launcher_on_primary_color"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/launcherAvatarImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="用户头像"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="13dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAccountMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本地模式"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="12sp"
                />

                <TextView
                    android:id="@+id/tvStateTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="本地玩家"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:id="@+id/actionProfileMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/launcher_white_card"
                android:clickable="true"
                android:contentDescription="菜单"
                android:focusable="true"
                android:gravity="center"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/launcher_action_menu" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/homeStatsCard"
            android:layout_width="match_parent"
            android:layout_height="153dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/launcher_balance_card"
            android:clipToOutline="true">

            <ImageView
                android:id="@+id/homeStatsImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:scaleType="centerCrop"
                android:src="@drawable/launcher_home_stats_bg" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:importantForAccessibility="no"
                android:orientation="horizontal">

                <View
                    android:id="@+id/homeStatsScrim"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/launcher_home_stats_scrim" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="游戏总数"
                    android:textColor="@color/launcher_on_primary_color"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvGameCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="@color/launcher_on_primary_color"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="27dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="累计游玩"
                            android:textColor="@color/launcher_on_primary_color"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvTotalPlayTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0s"
                            android:textColor="@color/launcher_on_primary_color"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="今日游玩"
                            android:textColor="@color/launcher_on_primary_color"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvTodayPlayTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0s"
                            android:textColor="@color/launcher_on_primary_color"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_marginTop="18dp"
            android:alignmentMode="alignMargins"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="false">

            <LinearLayout
                android:id="@+id/actionChatRoom"
                android:layout_width="0dp"
                android:layout_height="47dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="7dp"
                android:background="@drawable/launcher_white_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp">

                <ImageView
                    android:id="@+id/actionChatRoomIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/launcher_action_chatroom"
                    android:src="@drawable/launcher_action_chatroom" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="@string/launcher_action_chatroom"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/actionResourceStation"
                android:layout_width="0dp"
                android:layout_height="47dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="7dp"
                android:background="@drawable/launcher_white_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp">

                <ImageView
                    android:id="@+id/actionResourceStationIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/launcher_action_resources"
                    android:src="@drawable/launcher_action_resources" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="@string/launcher_action_resources"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/actionToolbox"
                android:layout_width="0dp"
                android:layout_height="47dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/launcher_white_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp">

                <ImageView
                    android:id="@+id/actionToolboxIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/launcher_action_toolbox"
                    android:src="@drawable/launcher_action_toolbox" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="@string/launcher_action_toolbox"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/actionAgent"
                android:layout_width="0dp"
                android:layout_height="47dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/launcher_white_card"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="13dp">

                <ImageView
                    android:id="@+id/actionAgentIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="@string/launcher_action_agent"
                    android:src="@drawable/launcher_action_agent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="7dp"
                    android:text="@string/launcher_action_agent"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最近动态"
                android:textColor="@color/launcher_text_color"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/recentEmpty"
                android:layout_width="match_parent"
                android:layout_height="68dp"
                android:layout_marginTop="11dp"
                android:background="@drawable/launcher_white_card"
                android:gravity="center"
                android:text="还没有游玩记录"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/recentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="11dp"
                android:orientation="vertical"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
