<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/recentRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:paddingBottom="@dimen/launcher_nav_overlay_scroll_bottom_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/launcher_home_content_horizontal_padding"
            android:paddingTop="@dimen/launcher_home_content_top_padding"
            android:paddingEnd="@dimen/launcher_home_content_horizontal_padding"
            android:paddingBottom="@dimen/launcher_home_content_bottom_padding">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/launcher_home_header_height"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/launcherAvatarContainer"
                    android:layout_width="@dimen/launcher_home_avatar_size"
                    android:layout_height="@dimen/launcher_home_avatar_size"
                    android:background="@drawable/launcher_avatar"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless">

                    <TextView
                        android:id="@+id/launcherAvatarInitial"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Y"
                        android:textColor="@color/launcher_on_primary_color"
                        android:textSize="@dimen/launcher_home_avatar_text_size"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/launcherAvatarImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="用户头像"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/launcher_home_header_text_margin_start"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAccountMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="本地模式"
                        android:textColor="@color/launcher_text_muted_color"
                        android:textSize="@dimen/launcher_home_account_mode_text_size" />

                    <TextView
                        android:id="@+id/tvStateTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/launcher_home_state_title_margin_top"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="本地玩家"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="@dimen/launcher_home_state_title_text_size"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/actionProfileMenu"
                    android:layout_width="@dimen/launcher_home_menu_size"
                    android:layout_height="@dimen/launcher_home_menu_size"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:contentDescription="菜单"
                    android:focusable="true"
                    android:gravity="center"
                    android:padding="@dimen/launcher_home_menu_padding"
                    android:scaleType="centerInside"
                    android:src="@drawable/launcher_action_menu" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/homeStatsCard"
                android:layout_width="match_parent"
                android:layout_height="@dimen/launcher_home_stats_card_height"
                android:layout_marginTop="@dimen/launcher_home_stats_card_margin_top"
                android:background="@drawable/launcher_balance_card"
                android:clipToOutline="true">

                <ImageView
                    android:id="@+id/homeStatsImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    android:src="@drawable/launcher_home_stats_bg" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:importantForAccessibility="no"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/homeStatsScrim"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/launcher_home_stats_scrim" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="@dimen/launcher_home_stats_card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="游戏总数"
                        android:textColor="@color/launcher_on_primary_color"
                        android:textSize="@dimen/launcher_home_stats_label_text_size" />

                    <TextView
                        android:id="@+id/tvGameCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/launcher_home_stats_value_margin_top"
                        android:text="0"
                        android:textColor="@color/launcher_on_primary_color"
                        android:textSize="@dimen/launcher_home_game_count_text_size"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/launcher_home_stats_column_gap"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="累计游玩"
                                android:textColor="@color/launcher_on_primary_color"
                                android:textSize="@dimen/launcher_home_stats_label_text_size" />

                            <TextView
                                android:id="@+id/tvTotalPlayTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/launcher_home_stats_value_margin_top"
                                android:text="0s"
                                android:textColor="@color/launcher_on_primary_color"
                                android:textSize="@dimen/launcher_home_stats_value_text_size"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="今日游玩"
                                android:textColor="@color/launcher_on_primary_color"
                                android:textSize="@dimen/launcher_home_stats_label_text_size" />

                            <TextView
                                android:id="@+id/tvTodayPlayTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/launcher_home_stats_value_margin_top"
                                android:text="0s"
                                android:textColor="@color/launcher_on_primary_color"
                                android:textSize="@dimen/launcher_home_stats_value_text_size"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/launcher_home_actions_grid_height"
                android:layout_marginTop="@dimen/launcher_home_actions_grid_margin_top"
                android:alignmentMode="alignMargins"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="false">

                <LinearLayout
                    android:id="@+id/actionSaveSlot"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/launcher_home_action_height"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="@dimen/launcher_home_action_half_gap"
                    android:layout_marginBottom="@dimen/launcher_home_action_row_gap"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/launcher_home_action_horizontal_padding">

                    <ImageView
                        android:id="@+id/actionSaveSlotIcon"
                        android:layout_width="@dimen/launcher_home_action_icon_size"
                        android:layout_height="@dimen/launcher_home_action_icon_size"
                        android:contentDescription="@string/launcher_action_save_slot"
                        android:src="@drawable/launcher_profile_action_save" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/launcher_home_action_text_gap"
                        android:text="@string/launcher_action_save_slot"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="@dimen/launcher_home_action_text_size"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionResourceStation"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/launcher_home_action_height"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="@dimen/launcher_home_action_half_gap"
                    android:layout_marginBottom="@dimen/launcher_home_action_row_gap"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/launcher_home_action_horizontal_padding">

                    <ImageView
                        android:id="@+id/actionResourceStationIcon"
                        android:layout_width="@dimen/launcher_home_action_icon_size"
                        android:layout_height="@dimen/launcher_home_action_icon_size"
                        android:contentDescription="@string/launcher_action_resources"
                        android:src="@drawable/launcher_action_resources" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/launcher_home_action_text_gap"
                        android:text="@string/launcher_action_resources"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="@dimen/launcher_home_action_text_size"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionToolbox"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/launcher_home_action_height"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="@dimen/launcher_home_action_half_gap"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/launcher_home_action_horizontal_padding">

                    <ImageView
                        android:id="@+id/actionToolboxIcon"
                        android:layout_width="@dimen/launcher_home_action_icon_size"
                        android:layout_height="@dimen/launcher_home_action_icon_size"
                        android:contentDescription="@string/launcher_action_toolbox"
                        android:src="@drawable/launcher_action_toolbox" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/launcher_home_action_text_gap"
                        android:text="@string/launcher_action_toolbox"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="@dimen/launcher_home_action_text_size"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/actionAgent"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/launcher_home_action_height"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="@dimen/launcher_home_action_half_gap"
                    android:background="@drawable/launcher_white_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/launcher_home_action_horizontal_padding">

                    <ImageView
                        android:id="@+id/actionAgentIcon"
                        android:layout_width="@dimen/launcher_home_action_icon_size"
                        android:layout_height="@dimen/launcher_home_action_icon_size"
                        android:contentDescription="@string/launcher_action_agent"
                        android:src="@drawable/launcher_action_agent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/launcher_home_action_text_gap"
                        android:text="@string/launcher_action_agent"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="@dimen/launcher_home_action_text_size"
                        android:textStyle="bold" />
                </LinearLayout>
            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/launcher_home_recent_section_margin_top"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最近动态"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="@dimen/launcher_home_recent_title_text_size"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/recentEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/launcher_home_recent_empty_height"
                    android:layout_marginTop="@dimen/launcher_home_recent_content_margin_top"
                    android:background="@drawable/launcher_white_card"
                    android:gravity="center"
                    android:text="还没有游玩记录"
                    android:textColor="@color/launcher_text_muted_color"
                    android:textSize="@dimen/launcher_home_recent_text_size" />

                <LinearLayout
                    android:id="@+id/recentList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/launcher_home_recent_content_margin_top"
                    android:orientation="vertical"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
