<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/addGameScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="31dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <TextView
                android:id="@+id/addGameTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="添加游戏"
                android:textColor="@color/launcher_text_color"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/addGameHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="13dp"
                android:lineSpacingExtra="3dp"
                android:text="填写信息后保存到游戏库"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="11sp" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:layout_marginTop="22dp"
                android:text="游戏名称" />

            <EditText
                android:id="@+id/addGameNameInput"
                style="@style/LauncherAddGameInput"
                android:hint="输入游戏名称" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="游戏引擎" />

            <TextView
                android:id="@+id/addGameEngineText"
                style="@style/LauncherAddGameInputText"
                android:text="自动识别" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="游戏目录" />

            <TextView
                android:id="@+id/addGameDirText"
                style="@style/LauncherAddGameInputText"
                android:text="点击选择游戏目录" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="封面图片" />

            <TextView
                android:id="@+id/addGameCoverText"
                style="@style/LauncherAddGameInputText"
                android:text="点击选择封面图片" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="启动入口" />

            <TextView
                android:id="@+id/addGameLaunchTargetInput"
                style="@style/LauncherAddGameInputText"
                android:text="点击选择启动文件" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="GameHub localGameId" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/addGameGameHubIdInput"
                    android:layout_width="0dp"
                    android:layout_height="45dp"
                    android:layout_weight="1"
                    android:background="@drawable/launcher_account_input"
                    android:hint="仅 GameHub，需要 Shizuku 导入或手填"
                    android:inputType="text"
                    android:paddingStart="13dp"
                    android:paddingEnd="13dp"
                    android:textColor="@color/launcher_text_color"
                    android:textColorHint="@color/launcher_input_hint_color"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/addGameImportGameHubShortcut"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="7dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:contentDescription="导入 GameHub 快捷方式"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/launcher_import_gamehub_shortcut" />
            </LinearLayout>

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="模拟器包名" />

            <TextView
                android:id="@+id/addGameEmulatorInput"
                style="@style/LauncherAddGameInputText"
                android:hint="点击选择模拟器应用" />

            <TextView
                style="@style/LauncherAddGameLabel"
                android:text="备注" />

            <EditText
                android:id="@+id/addGameDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:gravity="top"
                android:hint="可选"
                android:paddingStart="13dp"
                android:paddingTop="11dp"
                android:paddingEnd="13dp"
                android:paddingBottom="11dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/addGameSave"
                style="@style/LauncherLongActionButton"
                android:layout_marginTop="20dp"
                android:text="保存"
                />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
