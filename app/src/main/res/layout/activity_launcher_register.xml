<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/registerScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="25dp"
            android:paddingEnd="20dp"
            android:paddingBottom="25dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="43dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="立即注册"
                    android:textColor="@color/launcher_text_color"
                    android:textSize="23sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <Space
                android:layout_width="match_parent"
                android:layout_height="23dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="输入昵称"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/registerName"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="请你的输入昵称"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="输入邮箱"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/registerEmail"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="请输入你的邮箱"
                android:inputType="textEmailAddress"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="邮箱验证码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="7dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/registerVerificationCode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/launcher_account_input"
                    android:hint="请输入 6 位验证码"
                    android:inputType="number"
                    android:maxLength="6"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/launcher_text_color"
                    android:textColorHint="@color/launcher_input_hint_color"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/registerSendCode"
                    style="@style/LauncherInlineActionButton"
                    android:layout_width="106dp"
                    android:layout_marginStart="9dp"
                    android:text="获取验证码"
                    />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="输入密码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/registerPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="请输入你的密码"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="确认密码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/registerConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="请再次输入密码"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

                <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="输入邀请码"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp"
                android:textStyle="bold" />

                <EditText
                android:id="@+id/registerKey"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/launcher_account_input"
                android:hint="输入你的邀请码"
                android:inputType="textPassword"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="@color/launcher_text_color"
                android:textColorHint="@color/launcher_input_hint_color"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="9dp"
                android:gravity="center"
                android:text="密码至少 6 位；验证码有效期为 5 分钟"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/registerCreate"
                style="@style/LauncherLongActionButton"
                android:layout_marginTop="25dp"
                android:text="创建账户"
                />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
