<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <com.apps.LauncherParticleView
        android:id="@+id/launcherParticleView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/launcherFragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="94dp"
        android:background="@drawable/launcher_bottom_bar"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/navSelectionIndicator"
            android:layout_width="0dp"
            android:layout_height="66dp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/launcher_nav_selected" />

        <LinearLayout
            android:id="@+id/bottomNavItems"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/navHome"
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:background="@drawable/launcher_nav_unselected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                android:id="@+id/navHomeIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="H"
                android:textColor="@color/launcher_primary_color"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navHomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="首页"
                android:textColor="@color/launcher_primary_color"
                android:textSize="11sp"
                android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSavings"
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:background="@drawable/launcher_nav_unselected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                android:id="@+id/navSavingsIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="G"
                android:textColor="@color/launcher_nav_muted_color"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navSavingsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="游戏"
                android:textColor="@color/launcher_nav_muted_color"
                android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navLaunchCenter"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

            <FrameLayout
                android:id="@+id/navLaunchCenterCircle"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/launcher_icon_circle_green"
                android:elevation="3dp">

                <ImageView
                    android:id="@+id/navLaunchCenterImage"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/game_center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/launcher_game_center_default" />

                <ImageView
                    android:id="@+id/navLaunchCenterText"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/game_center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/launcher_theme_rinne_def"
                    android:visibility="gone" />
            </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navCards"
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:background="@drawable/launcher_nav_unselected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                android:id="@+id/navCardsIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S"
                android:textColor="@color/launcher_nav_muted_color"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navCardsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="管理"
                android:textColor="@color/launcher_nav_muted_color"
                android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAccount"
                android:layout_width="0dp"
                android:layout_height="66dp"
                android:layout_weight="1"
                android:background="@drawable/launcher_nav_unselected"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

            <TextView
                android:id="@+id/navAccountIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="M"
                android:textColor="@color/launcher_nav_muted_color"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navAccountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="账户"
                android:textColor="@color/launcher_nav_muted_color"
                android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
