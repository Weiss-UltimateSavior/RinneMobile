<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <ScrollView
        android:id="@+id/imagePreviewScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="34dp"
            android:paddingEnd="22dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/imagePreviewTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/launcher_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/imagePreviewMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="13sp" />

            <FrameLayout
                android:id="@+id/imagePreviewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <ProgressBar
                    android:id="@+id/imagePreviewLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:indeterminateTint="@color/launcher_primary_color" />

                <ImageView
                    android:id="@+id/imagePreviewView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/imagePreviewButtons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/imagePreviewShare"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@drawable/launcher_account_primary_button"
                    android:gravity="center"
                    android:text="分享图片"
                    android:textColor="@color/launcher_on_primary_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/imagePreviewSave"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/launcher_filter_chip_unselected"
                    android:gravity="center"
                    android:text="保存到相册"
                    android:textColor="@color/launcher_primary_color"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/imagePreviewClose"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/launcher_filter_chip_unselected"
                android:gravity="center"
                android:text="关闭"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/imagePreviewFullScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/launcher_bg_color"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imagePreviewFullScreenImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/imagePreviewFullScreenClose"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|top"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/launcher_filter_chip_unselected"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="退出全屏"
            android:textColor="@color/launcher_text_color"
            android:textSize="13sp" />
    </FrameLayout>
</FrameLayout>
