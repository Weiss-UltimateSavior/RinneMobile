<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/publicChatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:paddingTop="12dp" android:paddingBottom="8dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="公共聊天室" android:textColor="@color/launcher_text_color" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:id="@+id/publicChatConnection" android:layout_width="wrap_content" android:layout_height="wrap_content" android:ellipsize="end" android:maxWidth="150dp" android:text="连接中" android:textColor="@color/launcher_text_muted_color" android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout android:id="@+id/publicChatAnnouncementBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/launcher_white_card" android:gravity="center_vertical" android:padding="12dp">
        <TextView android:id="@+id/publicChatAnnouncementIcon" android:layout_width="25dp" android:layout_height="25dp" android:gravity="center" android:text="!" android:textColor="@android:color/white" android:textStyle="bold" />
        <TextView android:id="@+id/publicChatNotice" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="9dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="2" android:text="暂无公告" android:textColor="@color/launcher_text_color" android:textSize="12sp" />
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/publicChatMessages" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:clipToPadding="false" android:paddingTop="8dp" android:paddingBottom="8dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="10dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@android:color/transparent" android:orientation="horizontal" android:paddingBottom="6dp">
            <TextView android:id="@+id/publicChatPlaytimePlaceholder" android:layout_width="wrap_content" android:layout_height="31dp" android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp" android:text="游玩时长" android:textColor="@color/launcher_text_muted_color" android:textSize="11sp" />
            <TextView android:id="@+id/publicChatGameInfoPlaceholder" android:layout_width="wrap_content" android:layout_height="31dp" android:layout_marginStart="7dp" android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp" android:text="游戏信息" android:textColor="@color/launcher_text_muted_color" android:textSize="11sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/launcher_white_card" android:gravity="center_vertical" android:paddingStart="8dp" android:paddingTop="3dp" android:paddingEnd="8dp" android:paddingBottom="3dp">
            <EditText android:id="@+id/publicChatInput" style="@style/LauncherAddGameInput" android:layout_width="0dp" android:layout_height="33dp" android:layout_marginTop="0dp" android:layout_weight="1" android:background="@null" android:includeFontPadding="false" android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp" android:hint="说点什么…" android:inputType="textMultiLine|textCapSentences" android:maxLength="2000" android:maxLines="4" />
            <ImageView android:id="@+id/publicChatSend" android:layout_width="56dp" android:layout_height="43dp" android:layout_marginStart="4dp" android:contentDescription="发送消息" android:padding="6dp" android:scaleType="centerInside" android:src="@drawable/launcher_ic_send" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
