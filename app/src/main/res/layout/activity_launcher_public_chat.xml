<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/publicChatRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launcher_bg">

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/publicChatMessages" android:layout_width="match_parent" android:layout_height="match_parent" android:clipToPadding="false" android:scrollbars="none" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="8dp" />

    <LinearLayout android:id="@+id/publicChatTopOverlay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="top" android:clipToPadding="false" android:elevation="6dp" android:orientation="vertical">
        <LinearLayout android:id="@+id/publicChatTitleBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:paddingStart="13dp" android:paddingTop="12dp" android:paddingEnd="13dp" android:paddingBottom="15dp">
            <TextView android:id="@+id/publicChatTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="公共聊天室" android:textColor="@color/launcher_text_color" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/publicChatConnection" android:layout_width="wrap_content" android:layout_height="wrap_content" android:ellipsize="end" android:maxWidth="150dp" android:text="连接中" android:textColor="@color/launcher_text_muted_color" android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout android:id="@+id/publicChatAnnouncementBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:background="@drawable/launcher_white_card" android:gravity="center_vertical" android:padding="12dp">
            <TextView android:id="@+id/publicChatAnnouncementIcon" android:layout_width="25dp" android:layout_height="25dp" android:gravity="center" android:text="!" android:textColor="@android:color/white" android:textStyle="bold" />
            <TextView android:id="@+id/publicChatNotice" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="9dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="2" android:text="暂无公告" android:textColor="@color/launcher_text_color" android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/publicChatComposerOverlay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:elevation="6dp" android:orientation="vertical">
        <LinearLayout android:id="@+id/publicChatInputThemeBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingTop="4dp" android:paddingBottom="4dp">
            <LinearLayout android:id="@+id/publicChatInputContainer" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:background="@drawable/launcher_white_card" android:gravity="center_vertical" android:paddingStart="8dp" android:paddingTop="3dp" android:paddingEnd="8dp" android:paddingBottom="3dp">
                <EditText android:id="@+id/publicChatInput" style="@style/LauncherAddGameInput" android:layout_width="0dp" android:layout_height="33dp" android:layout_marginTop="0dp" android:layout_weight="1" android:background="@null" android:includeFontPadding="false" android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp" android:hint="说点什么…" android:inputType="textMultiLine|textCapSentences" android:maxLength="2000" android:maxLines="4" />
                <ImageView android:id="@+id/publicChatSend" android:layout_width="56dp" android:layout_height="43dp" android:layout_marginStart="4dp" android:contentDescription="发送消息" android:padding="6dp" android:scaleType="centerInside" android:src="@drawable/launcher_ic_send" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
