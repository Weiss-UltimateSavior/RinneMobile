<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/libraryContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:paddingStart="@dimen/launcher_library_content_horizontal_padding"
        android:paddingTop="@dimen/launcher_library_content_top_padding"
        android:paddingEnd="@dimen/launcher_library_content_horizontal_padding"
        android:paddingBottom="@dimen/launcher_library_content_bottom_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/launcher_library_toolbar_height"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/libraryTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="游戏库"
                android:textColor="@color/launcher_text_color"
                android:textSize="@dimen/launcher_library_title_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/librarySyncButton"
                android:layout_width="@dimen/launcher_library_toolbar_button_width"
                android:layout_height="@dimen/launcher_library_toolbar_button_height"
                android:layout_marginEnd="@dimen/launcher_library_sync_button_margin_end"
                android:background="@drawable/launcher_filter_chip_unselected"
                android:gravity="center"
                android:text="同步"
                android:textColor="@color/launcher_primary_color"
                android:textSize="@dimen/launcher_library_toolbar_button_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/libraryCollapseButton"
                android:layout_width="@dimen/launcher_library_toolbar_button_width"
                android:layout_height="@dimen/launcher_library_toolbar_button_height"
                android:layout_marginEnd="@dimen/launcher_library_collapse_button_margin_end"
                android:background="@drawable/launcher_filter_chip_unselected"
                android:gravity="center"
                android:text="收起"
                android:textColor="@color/launcher_primary_color"
                android:textSize="@dimen/launcher_library_toolbar_button_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/librarySearchButton"
                android:layout_width="@dimen/launcher_library_toolbar_button_width"
                android:layout_height="@dimen/launcher_library_toolbar_button_height"
                android:background="@drawable/launcher_filter_chip_unselected"
                android:gravity="center"
                android:text="搜索"
                android:textColor="@color/launcher_primary_color"
                android:textSize="@dimen/launcher_library_toolbar_button_text_size"
                android:textStyle="bold" />
        </LinearLayout>

        <EditText
            android:id="@+id/librarySearchInput"
            android:layout_width="match_parent"
            android:layout_height="@dimen/launcher_library_search_height"
            android:layout_marginTop="@dimen/launcher_library_search_margin_top"
            android:background="@drawable/launcher_white_card"
            android:hint="输入游戏名称"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="@dimen/launcher_library_search_horizontal_padding"
            android:paddingEnd="@dimen/launcher_library_search_horizontal_padding"
            android:textColor="@color/launcher_text_color"
            android:textColorHint="@color/launcher_text_muted_color"
            android:textSize="@dimen/launcher_library_search_text_size"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/libraryCategoryScroll"
            android:layout_width="match_parent"
            android:layout_height="@dimen/launcher_library_category_scroll_height"
            android:layout_marginTop="@dimen/launcher_library_category_margin_top"
            android:fillViewport="false"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/libraryCategoryRow"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="@dimen/launcher_library_list_margin_top"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/libraryRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/launcher_library_recycler_bottom_padding"
                android:visibility="gone" />

            <TextView
                android:id="@+id/libraryEmpty"
                android:layout_width="match_parent"
                android:layout_height="@dimen/launcher_library_empty_height"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="还没有游戏"
                android:textColor="@color/launcher_text_muted_color"
                android:textSize="@dimen/launcher_library_empty_text_size"
                android:visibility="gone" />

            <TextView
                android:id="@+id/libraryFooter"
                android:layout_width="match_parent"
                android:layout_height="@dimen/launcher_library_footer_height"
                android:layout_gravity="bottom"
                android:gravity="center"
                android:text="正在加载..."
                android:textColor="@color/launcher_text_color"
                android:textSize="@dimen/launcher_library_footer_text_size"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
