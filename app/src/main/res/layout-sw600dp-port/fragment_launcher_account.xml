<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!--
        平板竖屏专用布局：
        1. 内容区固定为 520dp 并居中，避免在大屏上被无限拉宽。
        2. 输入框、按钮、标题和间距按手机布局约 1.15～1.25 倍放大。
        3. View ID 与手机布局完全一致，ViewBinding 和 Fragment 代码可直接复用。
    -->
    <ScrollView
        android:id="@+id/accountScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="40dp"
            android:paddingTop="48dp"
            android:paddingEnd="40dp"
            android:paddingBottom="48dp">

            <LinearLayout
                android:layout_width="520dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="16dp">

                    <TextView
                        android:id="@+id/accountLogo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rinne Mobile"
                        android:textColor="@color/launcher_primary_color"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/accountTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="欢迎回来"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="30sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="28dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btnGoogle"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/launcher_account_social_button"
                        android:gravity="center"
                        android:text="QQ群聊"
                        android:textColor="@color/launcher_primary_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnFacebook"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        android:background="@drawable/launcher_account_social_button"
                        android:gravity="center"
                        android:text="官网首页"
                        android:textColor="@color/launcher_primary_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/launcher_line_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:text="登录或使用以上方式获取邀请码注册"
                        android:textColor="@color/launcher_text_muted_color"
                        android:textSize="15sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/launcher_line_color" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/accountForm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="昵称"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/inputName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/launcher_account_input"
                        android:hint="输入昵称"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/launcher_text_color"
                        android:textColorHint="@color/launcher_input_hint_color"
                        android:textSize="15sp"
                        android:visibility="gone" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="邮箱"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/inputEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/launcher_account_input"
                        android:hint="请输入邮箱"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/launcher_text_color"
                        android:textColorHint="@color/launcher_input_hint_color"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="密码"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/inputPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/launcher_account_input"
                        android:hint="请输入密码"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/launcher_text_color"
                        android:textColorHint="@color/launcher_input_hint_color"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/labelConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="确认密码"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/inputConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="7dp"
                        android:background="@drawable/launcher_account_input"
                        android:hint="请再次输入密码"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:textColor="@color/launcher_text_color"
                        android:textColorHint="@color/launcher_input_hint_color"
                        android:textSize="15sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/loginOptions"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="9dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <CheckBox
                            android:id="@+id/checkRemember"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:buttonTint="@color/launcher_primary_color"
                            android:checked="true"
                            android:gravity="center_vertical"
                            android:text="记住我"
                            android:textColor="@color/launcher_text_muted_color"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/forgotPassword"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:text="忘记密码？"
                            android:textColor="@color/launcher_primary_color"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <Space
                    android:layout_width="match_parent"
                    android:layout_height="84dp" />

                <TextView
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/launcher_account_primary_button"
                    android:gravity="center"
                    android:text="登录"
                    android:textColor="@color/launcher_on_primary_color"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/switchHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="还没有账户？"
                        android:textColor="@color/launcher_text_color"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/switchMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="注册"
                        android:textColor="@color/launcher_primary_color"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
